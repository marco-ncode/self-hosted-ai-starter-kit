POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Optional: set these only if you want to expose services via Caddy + public domains
# N8N_DOMAIN=n8n.example.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.example.com/
# N8N_EDITOR_BASE_URL=https://n8n.example.com/
# QDRANT_DOMAIN=qdrant.example.com
# SUPABASE_DOMAIN=supabase.example.com

# Optional: Supabase self-hosted settings (used by docker-compose.supabase.yml)
# Tip: generate these values with `sh supabase/generate-keys.sh --update-env`
# SUPABASE_PUBLIC_URL=https://supabase.example.com
# SUPABASE_SITE_URL=https://supabase.example.com
# SUPABASE_POSTGRES_DB=postgres
# SUPABASE_POSTGRES_PASSWORD=CHANGE_THIS_SUPABASE_DB_PASSWORD
# SUPABASE_JWT_SECRET=CHANGE_THIS_SUPABASE_JWT_SECRET_MIN_32_CHARS
# SUPABASE_ANON_KEY=CHANGE_THIS_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=CHANGE_THIS_SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SECRET_KEY_BASE=CHANGE_THIS_SUPABASE_SECRET_KEY_BASE_MIN_32_CHARS
# SUPABASE_DASHBOARD_USERNAME=supabase
# SUPABASE_DASHBOARD_PASSWORD=CHANGE_THIS_SUPABASE_DASHBOARD_PASSWORD
# SUPABASE_PGRST_DB_SCHEMAS=public,storage,graphql_public

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434
